{
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devPath": "http://localhost:3000",
    "distDir": "../dist"
  },
  "package": {
    "productName": "Megascan Studio",
    "version": "1.0.0"
  },
  "tauri": {
    "allowlist": {
      "all": true,
      "fs": {
        "all": true,
        "scope": ["$HOME/**", "C:\\**", "/Users/**", "/home/**"]
      },
      "shell": {
        "all": true,
        "sidecar": true
      },
      "http": {
        "all": true,
        "request": true,
        "scope": ["http://127.0.0.1:8000/**", "http://localhost:8000/**"]
      }
    },
    "bundle": {
      "active": true,
      "targets": "all",
      "identifier": "com.megascan.studio",
      "icon": [
        "icons/32x32.png",
        "icons/128x128.png",
        "icons/128x128@2x.png",
        "icons/icon.icns",
        "icons/icon.ico"
      ],
      "externalBin": [
        "binaries/python-backend"
      ]
    },
    "security": {
      "csp": null
    },
    "windows": [
      {
        "title": "Megascan Studio",
        "width": 1280,
        "height": 800,
        "resizable": true,
        "fullscreen": false,
        "decorations": false,
        "transparent": true,
        "theme": "Dark"
      }
    ]
  }
}
